    ],
    "/proizvodi/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/proizvodi/page.js"
    ],
    "/prodavnica/[...segments]/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/prodavnica/[...segments]/page.js"
    ]
