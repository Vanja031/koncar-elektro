# WordPress / WooCommerce API — kopirati u .env.local (ne commitovati)

# Produkcijski WP (default)
NEXT_PUBLIC_WP_API_URL=https://koncarelektro.rs/wp-json
NEXT_PUBLIC_WC_STORE_API_URL=https://koncarelektro.rs/wp-json/wc/store/v1

# WooCommerce REST API v3 — samo za probe/sync skripte ili server-side pozive
# Kreirati u: WP Admin → WooCommerce → Settings → Advanced → REST API
NEXT_PUBLIC_WC_CONSUMER_KEY=
NEXT_PUBLIC_WC_CONSUMER_SECRET=

# Canonical domain for SEO (title/canonical/OG always point here)
NEXT_PUBLIC_CANONICAL_URL=https://koncarelektro.rs

# Poveži katalog na live WC podatke (samo GET, read-only)
# NEXT_PUBLIC_USE_LIVE_API=true

# --- Checkout (server-only; NE stavljati NEXT_PUBLIC_) ---
# Bez ovoga checkout ostaje mock i NE piše u live WooCommerce.
# WC_LIVE_CHECKOUT=true
#
# Dok je uključeno (default), ime/prezime u WC orderu su "Test Test"
# a napomena "TEST PORUDŽBINA" — bez obzira na formu.
# Za prave kupce kasnije: WC_CHECKOUT_FORCE_TEST_CUSTOMER=false
# WC_CHECKOUT_FORCE_TEST_CUSTOMER=true

# ISR revalidate intervals (seconds) — optional overrides
# NEXT_PUBLIC_ISR_REVALIDATE_PRODUCT=600
# NEXT_PUBLIC_ISR_REVALIDATE_CATEGORY=900
# NEXT_PUBLIC_ISR_REVALIDATE_SALE=300
# NEXT_PUBLIC_ISR_REVALIDATE_HOME=600

# App origin for local dev (optional)
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
