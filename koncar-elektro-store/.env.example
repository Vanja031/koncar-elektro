# WordPress / WooCommerce API — kopirati u .env.local (ne commitovati)

# Produkcijski WP (default)
VITE_WP_API_URL=https://koncarelektro.rs/wp-json
VITE_WC_STORE_API_URL=https://koncarelektro.rs/wp-json/wc/store/v1

# WooCommerce REST API v3 — samo za probe/sync skripte ili server-side pozive
# Kreirati u: WP Admin → WooCommerce → Settings → Advanced → REST API
VITE_WC_CONSUMER_KEY=
VITE_WC_CONSUMER_SECRET=

# Poveži stranice proizvoda/kategorija na live WC podatke (read-only)
VITE_USE_LIVE_API=true
